{
  "name": "ai-teacher-evaluator-backend",
  "version": "1.0.0",
  "description": "AITeacherEvaluator backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test:unit": "jest --testPathPattern=tests/unit --passWithNoTests",
    "test:integration": "jest --testPathPattern=tests/integration --passWithNoTests --runInBand",
    "test": "npm run test:unit && npm run test:integration",
    "migrate": "tsx src/db/migrate.ts",
    "pdf:convert": "tsx src/scripts/convertPdfs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
